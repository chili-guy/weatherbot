# Polybot Weather — environment configuration
# Copy this file to .env and fill in the values.

# === Required for NWS (NOAA) API ===
# NWS requires an identifying User-Agent. Use a real contact.
POLYBOT_USER_AGENT="polybot-weather (your-email@example.com)"

# === Bankroll for Kelly sizing (USD) ===
POLYBOT_BANKROLL_USD=1000

# === Recommendation thresholds ===
POLYBOT_MIN_EDGE=0.05            # 5 percentage points
POLYBOT_MIN_EV=0.10              # 10% expected return per dollar
POLYBOT_MIN_LIQUIDITY_USD=50     # min ask-side liquidity at best price
POLYBOT_MAX_HOURS_TO_RESOLUTION=72

# === Kelly sizing ===
POLYBOT_KELLY_FRACTION=0.25      # use 25% of full Kelly
POLYBOT_MAX_BET_FRACTION=0.05    # cap per bet at 5% of bankroll

# === Storage ===
POLYBOT_DB_URL=sqlite:///./polybot.db

# === Caching ===
POLYBOT_CACHE_DIR=./.cache
POLYBOT_FORECAST_TTL_SECONDS=1800        # 30 minutes
POLYBOT_CLIMATOLOGY_TTL_SECONDS=86400    # 24 hours

# === Execution (DANGEROUS — keep false unless you know what you're doing) ===
POLYBOT_EXECUTION_ENABLED=false
# Only used when execution is enabled. NEVER commit a real key.
# POLYBOT_PRIVATE_KEY=
# POLYBOT_FUNDER_ADDRESS=
